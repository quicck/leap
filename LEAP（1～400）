            { en: "Land prices are gradually increasing.", ja: "土地の値段が徐々に上がっている。" },
            { en: "Even experts are only human, and therefore mistakes sometimes occur.", ja: "専門家でもただの人間だ。それゆえ、ミスが時々起きる。" },
            { en: "If you can't make it, your mother may go instead.", ja: "もし君が行けないのなら、君のお母さんが代わりに行ってもよい。" },
            { en: "We are open until 11 p.m. on weekdays.", ja: "平日は午後11時まで営業しています。" },
            { en: "learn another foreign language besides English", ja: "英語以外の（英語に加えて）外国語を勉強する" },
            { en: "Everybody was asleep except (for) him.", ja: "彼以外は皆眠っていた。" }
        ];

        let currentQuiz = [];
        let currentIndex = 0;
        let sessionResults = [];
        let score = 0;

        function initList() {
            const listBody = document.getElementById('list-body');
            const totalText = document.getElementById('list-total-text');
            listBody.innerHTML = ''; 
            totalText.innerText = `Total: ${sentences.length} items`;

            sentences.forEach(s => {
                const row = document.createElement('tr');
                row.className = "hover:bg-slate-50 transition-colors";
                row.innerHTML = `
                    <td class="px-4 py-3 font-semibold text-indigo-600 align-top">${s.en}</td>
                    <td class="px-4 py-3 text-slate-600 align-top">${s.ja}</td>
                `;
                listBody.appendChild(row);
            });
        }

        function toggleList() {
            const list = document.getElementById('full-list');
            list.classList.toggle('hidden');
            if(!list.classList.contains('hidden')) {
                list.scrollIntoView({ behavior: 'smooth' });
            }
        }

        function startSession() {
            currentQuiz = [...sentences].sort(() => 0.5 - Math.random()).slice(0, 10);
            currentIndex = 0;
            sessionResults = [];
            score = 0;
            
            document.getElementById('home-screen').classList.add('hidden');
            document.getElementById('result-screen').classList.add('hidden');
            document.getElementById('quiz-screen').classList.remove('hidden');
            
            showQuestion();
        }

        function showQuestion() {
            const q = currentQuiz[currentIndex];
            document.getElementById('progress-text').innerText = `第 ${currentIndex + 1} / 10 問`;
            document.getElementById('japanese-text').innerText = q.ja;
            document.getElementById('user-input').value = "";
            document.getElementById('user-input').disabled = false;
            document.getElementById('result-area').classList.add('hidden');
            document.getElementById('auto-success-msg').classList.add('hidden');
            document.getElementById('check-btn').classList.remove('hidden');
            
            const inputEl = document.getElementById('user-input');
            inputEl.value = "";
            setTimeout(() => inputEl.focus(), 100);
        }

        function checkAnswer() {
            const userVal = document.getElementById('user-input').value.trim();
            const correctVal = currentQuiz[currentIndex].en;
            
            document.getElementById('correct-answer').innerText = correctVal;
            document.getElementById('result-area').classList.remove('hidden');
            document.getElementById('check-btn').classList.add('hidden');
            document.getElementById('user-input').disabled = true;

            // 簡易的な判定（大文字小文字/末尾ピリオドのみ許容）
            const normalize = (str) => str.toLowerCase().replace(/[.,?!]$/, "").trim();

            if (normalize(userVal) === normalize(correctVal)) {
                document.getElementById('auto-success-msg').classList.remove('hidden');
                document.getElementById('manual-buttons').classList.add('hidden');
                document.getElementById('next-button-area').classList.remove('hidden');
            } else {
                document.getElementById('auto-success-msg').classList.add('hidden');
                document.getElementById('manual-buttons').classList.remove('hidden');
                document.getElementById('next-button-area').classList.add('hidden');
            }
            
            document.getElementById('result-area').scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        }

        function recordAndNext(isCorrect) {
            sessionResults.push({
                ...currentQuiz[currentIndex],
                user: document.getElementById('user-input').value.trim(),
                isCorrect: isCorrect,
                status: 'done'
            });

            if (isCorrect) score++;

            if (currentIndex < 9) {
                currentIndex++;
                showQuestion();
            } else {
                showResults('セット完了！');
            }
        }

        function forceQuitQuiz() {
            const userVal = document.getElementById('user-input').value.trim();
            for (let i = currentIndex; i < currentQuiz.length; i++) {
                if (sessionResults.length <= i) {
                    sessionResults.push({
                        ...currentQuiz[i],
                        user: (i === currentIndex) ? userVal : "",
                        isCorrect: false,
                        status: 'incomplete'
                    });
                }
            }
            showResults('練習を中断しました');
        }

        function showResults(title) {
            document.getElementById('quiz-screen').classList.add('hidden');
            document.getElementById('result-screen').classList.remove('hidden');
            document.getElementById('result-title').innerText = title;
            document.getElementById('score-text').innerText = `${score} / 10`;

            const reviewDiv = document.getElementById('review-list');
            reviewDiv.innerHTML = "";
            
            sessionResults.forEach(res => {
                const item = document.createElement('div');
                let cardClass = "";
                let statusIcon = "";

                if (res.status === 'incomplete') {
                    cardClass = "pending-bg";
                    statusIcon = '<span class="bg-slate-400 text-white text-[10px] px-2 py-0.5 rounded-full mr-2">未完了</span>';
                } else if (res.isCorrect) {
                    cardClass = "correct-bg";
                    statusIcon = '<span class="bg-emerald-500 text-white text-[10px] px-2 py-0.5 rounded-full mr-2">正解</span>';
                } else {
                    cardClass = "wrong-bg";
                    statusIcon = '<span class="bg-rose-500 text-white text-[10px] px-2 py-0.5 rounded-full mr-2">不正解</span>';
                }

                item.className = `p-5 border-l-4 ${cardClass}`;
                item.innerHTML = `
                    <div class="flex items-center mb-1 text-slate-800 font-bold">${statusIcon}${res.ja}</div>
                    <div class="space-y-1 mt-2">
                        <p class="text-sm font-bold text-indigo-700 break-words">Ans: ${res.en}</p>
                        <p class="text-xs text-slate-400 font-medium break-words">Your: ${res.user || '---'}</p>
                    </div>
                `;
                reviewDiv.appendChild(item);
            });
            
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }

        window.onload = initList;
    </script>
</body>
</html>

