<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>LEAP（1～400）</title>
    <!-- Tailwind CSS (CDN) -->
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&family=Noto+Sans+JP:wght@400;700&display=swap');
        
        :root {
            --app-bg: #f8fafc;
            --card-bg: #ffffff;
            --accent: #4f46e5;
        }

        body { 
            font-family: 'Inter', 'Noto Sans JP', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
            background-color: var(--app-bg);
            -webkit-font-smoothing: antialiased;
            -moz-osx-font-smoothing: grayscale;
            margin: 0;
            padding: 0;
        }

        .correct-bg { background-color: #f0fdf4; border-color: #bbf7d0; }
        .wrong-bg { background-color: #fef2f2; border-color: #fecaca; }
        .pending-bg { background-color: #f8fafc; border-color: #e2e8f0; }

        textarea {
            appearance: none;
            -webkit-appearance: none;
            box-shadow: none;
        }

        .table-container {
            width: 100%;
            overflow-x: auto;
            -webkit-overflow-scrolling: touch;
            border-radius: 0.75rem;
        }

        * { -webkit-tap-highlight-color: transparent; }

        .fade-in {
            animation: fadeIn 0.3s ease-in-out;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(5px); }
            to { opacity: 1; transform: translateY(0); }
        }
    </style>
</head>
<body class="min-h-screen text-slate-800">
    <div id="app" class="max-w-3xl mx-auto px-4 py-6 sm:px-6 lg:py-10">
        
