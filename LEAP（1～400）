            <header class="text-center py-8">
                <div class="inline-block bg-indigo-600 p-4 rounded-3xl mb-4 shadow-xl shadow-indigo-200">
                    <span class="text-white text-4xl font-black tracking-tighter">L</span>
                </div>
                <h1 class="text-4xl font-black text-slate-900 tracking-tight mb-2 uppercase">LEAP</h1>
                <p class="text-slate-500 font-bold tracking-widest text-sm">1 〜 400</p>
            </header>
            
            <div class="grid gap-4">
