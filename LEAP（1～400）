            </div>

            <button onclick="location.reload()" class="w-full bg-white border-2 border-slate-200 py-4 rounded-2xl font-bold text-slate-600 hover:bg-slate-50 transition-all shadow-sm">
                トップへ戻る
            </button>
        </div>
    </div>

